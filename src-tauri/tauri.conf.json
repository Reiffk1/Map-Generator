{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Wayfinder Atelier",
  "version": "0.1.0",
  "identifier": "com.rpaul.wayfinderatelier",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Wayfinder Atelier",
        "label": "main",
        "width": 1680,
        "height": 1020,
        "minWidth": 1280,
        "minHeight": 760,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../public/assets/dungeon-core/**/*",
      "../public/assets/tilesets/**/*",
      "../public/assets/kenney/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
